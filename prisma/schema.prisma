generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  CPP
  JAVA
  PYTHON
  JAVASCRIPT
}

enum SubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  INTERNAL_ERROR
}

enum ContestStatus {
  DRAFT
  UPCOMING
  LIVE
  ENDED
}

enum AchievementType {
  STREAK
  SOLVED
  CONTEST
  TOPIC
  XP
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  role                Role                 @default(USER)
  xp                  Int                  @default(0)
  level               Int                  @default(1)
  currentStreak       Int                  @default(0)
  longestStreak       Int                  @default(0)
  lastActiveAt        DateTime?
  bannedAt            DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  submissions         Submission[]
  generatedProblems   Problem[]            @relation("GeneratedProblems")
  topicProgress       TopicProgress[]
  solvedProblems      SolvedProblem[]
  activityLogs        ActivityLog[]
  reports             Report[]
  userAchievements    UserAchievement[]
  contestParticipants ContestParticipant[]
  leaderboardEntries  LeaderboardEntry[]
  mockInterviews      MockInterview[]

  @@index([role])
  @@index([xp])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Topic {
  id             String          @id @default(cuid())
  slug           String          @unique
  title          String
  sortOrder      Int             @unique
  description    String
  theory         String          @db.Text
  notes          String          @db.Text
  visualGuide    String          @db.Text
  commonMistakes String[]
  prerequisites  String[]
  nextTopics     String[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  problems       Problem[]
  quizzes        Quiz[]
  progress       TopicProgress[]
  mockInterviews MockInterview[]

  @@index([sortOrder])
}

model Quiz {
  id          String   @id @default(cuid())
  topicId     String
  question    String
  options     Json
  answer      String
  explanation String   @db.Text
  createdAt   DateTime @default(now())
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Problem {
  id                 String           @id @default(cuid())
  slug               String           @unique
  title              String
  difficulty         Difficulty
  statement          String           @db.Text
  constraints        String[]
  examples           Json
  hiddenTestCases    Json
  expectedComplexity String
  hints              String[]
  editorial          String           @db.Text
  tags               String[]
  topicId            String
  createdById        String?
  isGenerated        Boolean          @default(false)
  acceptanceRate     Float            @default(0)
  submissionsCount   Int              @default(0)
  acceptedCount      Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  topic              Topic            @relation(fields: [topicId], references: [id], onDelete: Restrict)
  createdBy          User?            @relation("GeneratedProblems", fields: [createdById], references: [id], onDelete: SetNull)
  submissions        Submission[]
  solvedBy           SolvedProblem[]
  contestProblems    ContestProblem[]

  @@index([topicId, difficulty])
  @@index([createdById])
  @@index([isGenerated])
}

model Submission {
  id             String           @id @default(cuid())
  userId         String
  problemId      String
  language       Language
  sourceCode     String           @db.Text
  status         SubmissionStatus @default(QUEUED)
  passedTests    Int              @default(0)
  totalTests     Int              @default(0)
  runtimeMs      Int?
  memoryKb       Int?
  score          Int              @default(0)
  stdout         String?          @db.Text
  stderr         String?          @db.Text
  compileOutput  String?          @db.Text
  judge0Tokens   Json?
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  codeReview     AIReview?
  solvedProblem  SolvedProblem?

  @@index([userId, createdAt])
  @@index([problemId, status])
}

model AIReview {
  id            String     @id @default(cuid())
  submissionId  String     @unique
  correctness   String     @db.Text
  complexity    String     @db.Text
  mistakes      String[]
  optimizations String[]
  edgeCases     String[]
  score         Int
  summary       String     @db.Text
  createdAt     DateTime   @default(now())
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model TopicProgress {
  id               String   @id @default(cuid())
  userId           String
  topicId          String
  completion       Float    @default(0)
  problemsSolved   Int      @default(0)
  attempts         Int      @default(0)
  accuracy         Float    @default(0)
  timeSpentSeconds Int      @default(0)
  strengthScore    Float    @default(0)
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic            Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
}

model SolvedProblem {
  id                 String     @id @default(cuid())
  userId             String
  problemId          String
  bestSubmissionId   String?    @unique
  timeSpentSeconds   Int        @default(0)
  solvedAt           DateTime   @default(now())
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem            Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  bestSubmission     Submission? @relation(fields: [bestSubmissionId], references: [id], onDelete: SetNull)

  @@unique([userId, problemId])
  @@index([userId, solvedAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  solvedCount Int      @default(0)
  xpEarned    Int      @default(0)
  minutes     Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model Achievement {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  description      String
  type             AchievementType
  xpReward         Int
  unlockCondition  Json
  createdAt        DateTime          @default(now())
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Contest {
  id           String               @id @default(cuid())
  slug         String               @unique
  title        String
  description  String               @db.Text
  startsAt     DateTime
  endsAt       DateTime
  status       ContestStatus        @default(DRAFT)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  problems     ContestProblem[]
  participants ContestParticipant[]
  leaderboard  LeaderboardEntry[]

  @@index([status, startsAt])
}

model ContestProblem {
  id        String  @id @default(cuid())
  contestId String
  problemId String
  points    Int
  sortOrder Int
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemId])
  @@unique([contestId, sortOrder])
}

model ContestParticipant {
  id          String   @id @default(cuid())
  contestId   String
  userId      String
  score       Int      @default(0)
  penalty     Int      @default(0)
  rank        Int?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, score])
}

model LeaderboardEntry {
  id        String   @id @default(cuid())
  contestId String
  userId    String
  score     Int      @default(0)
  rank      Int
  updatedAt DateTime @updatedAt
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@unique([contestId, rank])
}

model Report {
  id        String       @id @default(cuid())
  userId    String
  period    ReportPeriod
  startsAt  DateTime
  endsAt    DateTime
  data      Json
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, startsAt])
  @@index([userId, period])
}

model MockInterview {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  question       Json
  answer         String?  @db.Text
  evaluation     Json?
  recommendation String?
  score          Int?
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          Topic    @relation(fields: [topicId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
}

model ApiUsage {
  id          String   @id @default(cuid())
  key         String
  route       String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, route, windowStart])
  @@index([route, windowStart])
}
